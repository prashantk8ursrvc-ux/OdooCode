# OdooCode Environment Variables & API Keys
# Copy this file to .env and fill in your keys:
# cp .env.example .env

# OpenAI API Key (Required if using openai/* models e.g. openai/gpt-4o)
OPENAI_API_KEY=

# Anthropic API Key (Required if using anthropic/* models e.g. anthropic/claude-3-5-sonnet-20241022)
ANTHROPIC_API_KEY=

# OpenRouter API Key (Required if using openrouter/* models)
OPENROUTER_API_KEY=

# Optional Custom Ollama Host URL (Defaults to http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
